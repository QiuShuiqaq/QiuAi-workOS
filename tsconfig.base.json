{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@qiuai/api-contract": ["packages/api-contract/src/index.ts"],
      "@qiuai/api-client": ["packages/api-client/src/index.ts"],
      "@qiuai/design-tokens": ["packages/design-tokens/src/index.ts"],
      "@qiuai/domain": ["packages/domain/src/index.ts"],
      "@qiuai/ui": ["packages/ui/src/index.ts"],
      "@qiuai/utils": ["packages/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".next", ".local"]
}
