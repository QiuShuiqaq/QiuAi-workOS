NODE_ENV=development
APP_ENV=local
WORKOS_DEPLOY_TARGET=local

# Server
WORKOS_PERSISTENCE_MODE=mock
WORKOS_MOCK_ADMIN_PASSWORD=qiuai-demo
WORKOS_BOOTSTRAP_ADMIN_PASSWORD=
SERVER_HOST=127.0.0.1
SERVER_PORT=4000
SERVER_API_BASE_URL=http://127.0.0.1:4000
SERVER_INTERNAL_BASE_URL=http://127.0.0.1:4000
DATABASE_URL=postgresql://qiuai:qiuai@127.0.0.1:5432/qiuai_workos
REDIS_URL=redis://127.0.0.1:6379/0

# Web
NEXT_PUBLIC_API_BASE_URL=

# Billing and payment
WORKOS_PUBLIC_BASE_URL=http://127.0.0.1:3000
PAYMENT_ALIPAY_APP_ID=
PAYMENT_ALIPAY_PRIVATE_KEY=
PAYMENT_ALIPAY_PUBLIC_KEY=
PAYMENT_ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
PAYMENT_ALIPAY_NOTIFY_PATH=/api/v1/billing/alipay/notify
PAYMENT_ALIPAY_RETURN_PATH=/billing/alipay/return
PAYMENT_ALIPAY_KEY_TYPE=PKCS8
PAYMENT_ALIPAY_SELLER_ID=

# Docker deployment
WEB_PUBLISHED_PORT=3000
SERVER_PUBLISHED_PORT=4000
SERVER_DATABASE_URL=
SERVER_REDIS_URL=
POSTGRES_DB=qiuai_workos
POSTGRES_USER=qiuai
POSTGRES_PASSWORD=qiuai_change_me

# Local tooling
NPM_CONFIG_CACHE=.local/npm-cache
NPM_CONFIG_LOGS_DIR=.local/npm-logs
