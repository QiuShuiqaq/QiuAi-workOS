NODE_ENV=production
WORKOS_DEPLOY_TARGET=alicloud-ecs

# QiuAI WorkOS runs independently from qiuai-platform on the same ECS host.
WORKOS_PUBLIC_BASE_URL=https://workos.qiuaihub.com
WORKOS_PERSISTENCE_MODE=mock
WORKOS_MOCK_ADMIN_PASSWORD=CHANGE_THIS_MOCK_PASSWORD

# Internal API server, reachable only by local Nginx/Next.js on the server.
SERVER_HOST=127.0.0.1
SERVER_PORT=4100
SERVER_API_BASE_URL=http://127.0.0.1:4100
SERVER_INTERNAL_BASE_URL=http://127.0.0.1:4100
NEXT_PUBLIC_API_BASE_URL=

# Keep WorkOS in a separate database. Set WORKOS_PERSISTENCE_MODE=database after bootstrap.
DATABASE_URL=postgresql://qiu_workos:CHANGE_THIS_DATABASE_PASSWORD@127.0.0.1:5432/qiuai_workos?schema=public
REDIS_URL=redis://127.0.0.1:6379/1
WORKOS_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD

# Reserved for billing integration. Do not commit real values.
WORKOS_ENTERPRISE_MONTHLY_PRICE_CENTS=
WORKOS_ENTERPRISE_ANNUAL_PRICE_CENTS=
PAYMENT_ALIPAY_APP_ID=
PAYMENT_ALIPAY_PRIVATE_KEY=
PAYMENT_ALIPAY_PUBLIC_KEY=
PAYMENT_ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
PAYMENT_ALIPAY_NOTIFY_PATH=/api/v1/billing/alipay/notify
PAYMENT_ALIPAY_RETURN_PATH=/billing/alipay/return
PAYMENT_ALIPAY_KEY_TYPE=PKCS8
PAYMENT_ALIPAY_SELLER_ID=
WORKOS_ALLOW_MANUAL_BILLING_AMOUNT=false
