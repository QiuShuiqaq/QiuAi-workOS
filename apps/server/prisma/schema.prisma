generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantType {
  PERSONAL
  ENTERPRISE
  PLATFORM
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum AccountStatus {
  ACTIVE
  DISABLED
}

enum WorkspaceType {
  PERSONAL
  ENTERPRISE
}

enum WorkspaceStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum WorkspaceMemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum PlanCode {
  PERSONAL_FREE
  ENTERPRISE_BASIC_MONTHLY
  ENTERPRISE_BASIC_ANNUAL
  ENTERPRISE_STANDARD_MONTHLY
  ENTERPRISE_STANDARD_ANNUAL
  ENTERPRISE_PRO_MONTHLY
  ENTERPRISE_PRO_ANNUAL
  ENTERPRISE_MONTHLY
  ENTERPRISE_ANNUAL
  ENTERPRISE_CUSTOM
}

enum BillingCycle {
  FREE
  MONTHLY
  ANNUAL
  CUSTOM
}

enum PlanStatus {
  ACTIVE
  ARCHIVED
}

enum SubscriptionStatus {
  FREE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum PaymentProvider {
  ALIPAY
}

enum BillingAccountStatus {
  ACTIVE
  DISABLED
}

enum BillingOrderStatus {
  PENDING
  PAID
  CLOSED
  CANCELLED
  FAILED
}

enum PaymentTransactionStatus {
  INITIATED
  SUCCEEDED
  FAILED
  CANCELLED
}

enum RoleInstanceStatus {
  RUNNING
  TRIAL
  CONFIGURATION_REQUIRED
  PAUSED
}

enum TaskStatus {
  QUEUED
  RUNNING
  WAITING_APPROVAL
  COMPLETED
  FAILED
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum TaskArtifactType {
  TEXT
  REPORT
  VIDEO
  IMAGE
  FILE
}

enum ExecutionLogLevel {
  INFO
  WARNING
  ERROR
}

model Account {
  id           String        @id @default(uuid()) @db.Uuid
  primaryEmail String        @unique @map("primary_email")
  phone        String?
  passwordHash String?       @map("password_hash")
  status       AccountStatus @default(ACTIVE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  memberships     WorkspaceMember[]
  authSessions    AuthSession[]

  @@map("accounts")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  accountId        String    @map("account_id") @db.Uuid
  sessionTokenHash String    @unique @map("session_token_hash")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  lastSeenAt       DateTime? @map("last_seen_at")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  type      TenantType
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  workspaces    Workspace[]
  organizations Organization[]

  @@map("tenants")
}

model Workspace {
  id             String          @id @default(uuid()) @db.Uuid
  tenantId       String          @map("tenant_id") @db.Uuid
  type           WorkspaceType
  name           String
  ownerAccountId String          @map("owner_account_id") @db.Uuid
  status         WorkspaceStatus @default(ACTIVE)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  ownerAccount   Account           @relation("WorkspaceOwner", fields: [ownerAccountId], references: [id], onDelete: Restrict)
  organization   Organization?
  memberships    WorkspaceMember[]
  subscriptions  Subscription[]
  usageMeters    UsageMeter[]
  billingAccount BillingAccount?
  billingOrders  BillingOrder[]
  roleInstances  RoleInstance[]
  tasks          Task[]
  costRecords    CostRecord[]
  desktopRuntimeSyncs DesktopRuntimeSync[]

  @@index([tenantId])
  @@index([ownerAccountId])
  @@map("workspaces")
}

model WorkspaceMember {
  id           String              @id @default(uuid()) @db.Uuid
  workspaceId  String              @map("workspace_id") @db.Uuid
  accountId    String              @map("account_id") @db.Uuid
  departmentId String?             @map("department_id") @db.Uuid
  role         WorkspaceMemberRole @default(MEMBER)
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  workspace        Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account          Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  department       Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  ownedDepartments Department[]   @relation("DepartmentOwner")
  ownedRoles       RoleInstance[] @relation("RoleInstanceOwner")

  @@unique([workspaceId, accountId])
  @@index([accountId])
  @@index([departmentId])
  @@map("workspace_members")
}

model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  workspaceId String   @unique @map("workspace_id") @db.Uuid
  name        String
  industry    String?
  size        String?
  settings    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  departments Department[]

  @@index([tenantId])
  @@map("organizations")
}

model Department {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  parentDepartmentId String?  @map("parent_department_id") @db.Uuid
  name               String
  ownerMemberId      String?  @map("owner_member_id") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentDepartment Department?       @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  childDepartments Department[]      @relation("DepartmentHierarchy")
  ownerMember      WorkspaceMember?  @relation("DepartmentOwner", fields: [ownerMemberId], references: [id], onDelete: SetNull)
  members          WorkspaceMember[]
  roleInstances    RoleInstance[]

  @@index([organizationId])
  @@index([parentDepartmentId])
  @@index([ownerMemberId])
  @@map("departments")
}

model Plan {
  id           String       @id @default(uuid()) @db.Uuid
  code         PlanCode     @unique
  name         String
  description  String?
  billingCycle BillingCycle @map("billing_cycle")
  priceCents   Int?         @map("price_cents")
  currency     String?
  status       PlanStatus   @default(ACTIVE)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  entitlements  Entitlement[]
  subscriptions Subscription[]
  billingOrders BillingOrder[]

  @@map("plans")
}

model Entitlement {
  id         String   @id @default(uuid()) @db.Uuid
  planId     String   @map("plan_id") @db.Uuid
  featureKey String   @map("feature_key")
  enabled    Boolean  @default(true)
  limitValue Int?     @map("limit_value")
  limitUnit  String?  @map("limit_unit")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@map("entitlements")
}

model Subscription {
  id                 String             @id @default(uuid()) @db.Uuid
  workspaceId        String             @map("workspace_id") @db.Uuid
  planId             String             @map("plan_id") @db.Uuid
  status             SubscriptionStatus
  billingCycle       BillingCycle       @map("billing_cycle")
  currentPeriodStart DateTime?          @map("current_period_start")
  currentPeriodEnd   DateTime?          @map("current_period_end")
  cancelAtPeriodEnd  Boolean            @default(false) @map("cancel_at_period_end")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan          Plan           @relation(fields: [planId], references: [id], onDelete: Restrict)
  billingOrders BillingOrder[]

  @@index([workspaceId])
  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}

model UsageMeter {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  metricKey   String    @map("metric_key")
  period      String
  usedValue   Int       @default(0) @map("used_value")
  resetAt     DateTime? @map("reset_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, metricKey, period])
  @@map("usage_meters")
}

model BillingAccount {
  id              String               @id @default(uuid()) @db.Uuid
  workspaceId     String               @unique @map("workspace_id") @db.Uuid
  status          BillingAccountStatus @default(ACTIVE)
  billingName     String?              @map("billing_name")
  taxId           String?              @map("tax_id")
  contactEmail    String?              @map("contact_email")
  defaultProvider PaymentProvider?     @map("default_provider")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  orders    BillingOrder[]

  @@map("billing_accounts")
}

model BillingOrder {
  id               String             @id @default(uuid()) @db.Uuid
  workspaceId      String             @map("workspace_id") @db.Uuid
  billingAccountId String?            @map("billing_account_id") @db.Uuid
  planId           String             @map("plan_id") @db.Uuid
  subscriptionId   String?            @map("subscription_id") @db.Uuid
  orderNo          String             @unique @map("order_no")
  provider         PaymentProvider
  status           BillingOrderStatus @default(PENDING)
  subject          String
  amountCents      Int                @map("amount_cents")
  currency         String             @default("CNY")
  billingCycle     BillingCycle       @map("billing_cycle")
  periodStart      DateTime?          @map("period_start")
  periodEnd        DateTime?          @map("period_end")
  paymentUrl       String?            @map("payment_url")
  providerTradeNo  String?            @map("provider_trade_no")
  metadata         Json?
  paidAt           DateTime?          @map("paid_at")
  expiresAt        DateTime?          @map("expires_at")
  closedAt         DateTime?          @map("closed_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  workspace      Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  billingAccount BillingAccount?      @relation(fields: [billingAccountId], references: [id], onDelete: SetNull)
  plan           Plan                 @relation(fields: [planId], references: [id], onDelete: Restrict)
  subscription   Subscription?        @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  transactions   PaymentTransaction[]

  @@index([workspaceId])
  @@index([billingAccountId])
  @@index([planId])
  @@index([subscriptionId])
  @@index([status])
  @@index([provider])
  @@map("billing_orders")
}

model PaymentTransaction {
  id              String                   @id @default(uuid()) @db.Uuid
  orderId         String                   @map("order_id") @db.Uuid
  provider        PaymentProvider
  status          PaymentTransactionStatus @default(INITIATED)
  amountCents     Int                      @map("amount_cents")
  currency        String                   @default("CNY")
  providerTradeNo String?                  @map("provider_trade_no")
  notifyPayload   Json?                    @map("notify_payload")
  failureCode     String?                  @map("failure_code")
  failureMessage  String?                  @map("failure_message")
  notifiedAt      DateTime?                @map("notified_at")
  completedAt     DateTime?                @map("completed_at")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  order BillingOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([provider, providerTradeNo])
  @@index([orderId])
  @@index([status])
  @@index([provider])
  @@map("payment_transactions")
}

model RoleTemplate {
  id                  String   @id
  name                String
  industry            String
  scenario            String
  description         String
  recommendedPlanCode String   @map("recommended_plan_code")
  businessGoal        String   @map("business_goal")
  knowledgeSources    Json     @map("knowledge_sources")
  tools               Json
  approvalPolicy      String   @map("approval_policy")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  roleInstances RoleInstance[]

  @@index([recommendedPlanCode])
  @@map("role_templates")
}

model RoleInstance {
  id               String             @id @default(uuid()) @db.Uuid
  templateId       String             @map("template_id")
  workspaceId      String             @map("workspace_id") @db.Uuid
  departmentId     String?            @map("department_id") @db.Uuid
  ownerMemberId    String?            @map("owner_member_id") @db.Uuid
  name             String
  status           RoleInstanceStatus @default(CONFIGURATION_REQUIRED)
  businessGoal     String             @map("business_goal")
  knowledgeSources Json               @map("knowledge_sources")
  tools            Json
  approvalPolicy   String             @map("approval_policy")
  installedAt      DateTime           @default(now()) @map("installed_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  template    RoleTemplate     @relation(fields: [templateId], references: [id], onDelete: Restrict)
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  department  Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  ownerMember WorkspaceMember? @relation("RoleInstanceOwner", fields: [ownerMemberId], references: [id], onDelete: SetNull)
  tasks       Task[]

  @@index([templateId])
  @@index([workspaceId])
  @@index([departmentId])
  @@index([ownerMemberId])
  @@index([status])
  @@map("role_instances")
}

model Task {
  id             String       @id @default(uuid()) @db.Uuid
  workspaceId    String       @map("workspace_id") @db.Uuid
  roleInstanceId String       @map("role_instance_id") @db.Uuid
  title          String
  taskType       String       @map("task_type")
  status         TaskStatus   @default(QUEUED)
  priority       TaskPriority @default(NORMAL)
  input          String
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  roleInstance RoleInstance   @relation(fields: [roleInstanceId], references: [id], onDelete: Restrict)
  runs         TaskRun[]
  artifacts    TaskArtifact[]
  logs         ExecutionLog[]
  costRecords  CostRecord[]

  @@index([workspaceId])
  @@index([roleInstanceId])
  @@index([status])
  @@index([priority])
  @@index([updatedAt])
  @@map("tasks")
}

model TaskRun {
  id         String        @id @default(uuid()) @db.Uuid
  taskId     String        @map("task_id") @db.Uuid
  status     TaskRunStatus @default(QUEUED)
  startedAt  DateTime?     @map("started_at")
  finishedAt DateTime?     @map("finished_at")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([status])
  @@index([createdAt])
  @@map("task_runs")
}

model TaskArtifact {
  id        String           @id @default(uuid()) @db.Uuid
  taskId    String           @map("task_id") @db.Uuid
  type      TaskArtifactType
  title     String
  content   String
  createdAt DateTime         @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([type])
  @@map("task_artifacts")
}

model ExecutionLog {
  id        String            @id @default(uuid()) @db.Uuid
  taskId    String            @map("task_id") @db.Uuid
  level     ExecutionLogLevel @default(INFO)
  eventType String            @map("event_type")
  message   String
  createdAt DateTime          @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([level])
  @@index([eventType])
  @@index([createdAt])
  @@map("execution_logs")
}

model CostRecord {
  id           String   @id @default(uuid()) @db.Uuid
  workspaceId  String   @map("workspace_id") @db.Uuid
  taskId       String   @map("task_id") @db.Uuid
  provider     String
  modelName    String   @map("model_name")
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  totalCost    Decimal  @map("total_cost") @db.Decimal(12, 4)
  currency     String   @default("CNY")
  createdAt    DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([taskId])
  @@index([provider])
  @@index([createdAt])
  @@map("cost_records")
}

model DesktopRuntimeSync {
  id             String   @id @default(uuid()) @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  runtimeId      String   @unique @map("runtime_id")
  deviceId       String   @map("device_id")
  deviceName     String   @map("device_name")
  platform       String
  appVersion     String   @map("app_version")
  runtimeSnapshot Json    @map("runtime_snapshot")
  syncedAt       DateTime @map("synced_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([syncedAt])
  @@map("desktop_runtime_syncs")
}
