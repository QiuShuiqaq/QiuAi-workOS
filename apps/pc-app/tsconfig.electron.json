{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "paths": {},
    "types": ["node"],
    "noEmit": false,
    "declaration": false,
    "sourceMap": true,
    "composite": false,
    "isolatedModules": false
  },
  "include": ["src/main", "src/preload", "src/shared"],
  "exclude": ["src/shared/**/*.test.ts"]
}
